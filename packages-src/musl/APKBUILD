# Maintainer: Volna Linux <volna@volna.linux>
pkgname=musl
pkgver=1.2.6
pkgrel=0
pkgdesc="musl libc — lightweight, fast, simple C standard library"
url="https://musl.libc.org/"
arch="x86_64"
license="MIT"
makedepends=""
subpackages="$pkgname-dev $pkgname-dbg"
source="https://musl.libc.org/releases/musl-$pkgver.tar.gz"
sha256sums="d585fd3b613c66151fc3249e8ed44f77020cb5e6c1e635a616d3f9f82460512a  musl-1.2.6.tar.gz"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--localstatedir=/var \
		--enable-wrapper=all
	make
}

package() {
	cd "$builddir"
	make DESTDIR="$pkgdir" install
}

dev() {
	default_dev
}
